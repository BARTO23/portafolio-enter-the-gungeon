---
const skills = [
  { name: "React", color: "#4cc9f0", level: 85 },
  { name: "Airflow", color: "#42b883", level: 75 },
  { name: "TypeScript", color: "#3178c6", level: 80 },
  { name: "Tailwind CSS", color: "#38bdf8", level: 90 },
  { name: "Python", color: "#f4a261", level: 70 },
  { name: "SQL", color: "#e63946", level: 65 },
  { name: "Docker", color: "#2496ed", level: 60 },
  { name: "Next.js", color: "#a0a0b0", level: 75 },
];
---

<section id="skills" class="min-h-screen py-20 px-4 relative" style="width: 100%;">
  <div class="absolute inset-0" style="background-color: #0a0a12;"></div>

  <div class="max-w-5xl mx-auto relative z-10" style="max-width: 64rem; margin: 0 auto; width: 100%;">
    <h2 class="font-pixel text-4xl md:text-5xl text-gold text-center mb-4 drop-shadow-[0_0_20px_rgba(244,162,97,0.3)]">
      ARMORY
    </h2>
    <p class="text-[#a0a0b0] text-center mb-12 font-heading">
      Mis habilidades y herramientas
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {skills.map((skill) => (
        <div class="skill-item group relative">
          <div class="item-card p-4 h-full" style="border: 3px solid #2a2a4a; background: #12121f; transition: all 0.3s;">
            <div class="item-header flex flex-col items-center mb-3">
              <svg class="mb-2" style={`width: 32px; height: 32px; color: ${skill.color};`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                {skill.name === "React" && <><circle cx="12" cy="12" r="4"/><path d="M8.5 8.5L12 3l3.5 5.5"/><path d="M8.5 15.5L12 21l3.5-5.5"/><path d="M3 12l5.5-3.5L12 12"/><path d="M21 12l-5.5 3.5L12 12"/></>}
                {skill.name === "Airflow" && <><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></>}
                {skill.name === "TypeScript" && <><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/></>}
                {skill.name === "Tailwind CSS" && <><rect x="4" y="4" width="4" height="4"/><rect x="10" y="4" width="4" height="4"/><rect x="16" y="4" width="4" height="4"/><rect x="4" y="10" width="4" height="4"/><rect x="10" y="10" width="4" height="4"/><rect x="16" y="10" width="4" height="4"/><rect x="4" y="16" width="4" height="4"/><rect x="10" y="16" width="4" height="4"/><rect x="16" y="16" width="4" height="4"/></>}
                {skill.name === "Python" && <><path d="M12 4v16"/><path d="M8 8c2-2 6-2 8 0s6 2 8 0"/><path d="M8 16c2-2 6-2 8 0"/></>}
                {skill.name === "SQL" && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></>}
                {skill.name === "Docker" && <><path d="M22 12.5c-1.5 1-3.5 1.5-6 1.5-2.5 0-4.5-.5-6-1.5h12z"/><path d="M4 8.5c0-1.5 2-2.5 5.5-2.5 1.5 0 3 .5 4 1"/><path d="M15 8.5V6c0-1.5 2-2.5 5.5-2.5 1.5 0 3 .5 4 1"/><path d="M9.5 20c-1.5 0-3-.5-4-1.5"/></>}
                {skill.name === "Next.js" && <><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></>}
              </svg>
              <span class="text-xs" style="color: #a0a0b0;">{skill.level}%</span>
            </div>
            <h3 class="font-pixel text-sm mb-2" style={`color: ${skill.color}; text-align: center; width: 100%;`}>
              {skill.name}
            </h3>
            <div class="progress-bar h-1 overflow-hidden" style="background: #2a2a4a; height: 4px;">
              <div class="progress-fill h-full" style={`width: 0%; background: ${skill.color};`} data-width={skill.level}></div>
            </div>
          </div>
          <div class="item-glow absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style={`box-shadow: inset 0 0 30px ${skill.color}33;`}></div>
        </div>
      ))}
    </div>

    <div class="mt-12 grid md:grid-cols-3 gap-6">
      <div class="category-card p-6" style="border: 3px solid #2a2a4a; background: rgba(18,18,31,0.5);">
        <h3 class="font-pixel text-lg mb-4" style="color: #e63946;">BACKEND</h3>
        <ul class="space-y-2 text-sm" style="color: #a0a0b0;">
          <li>Python</li>
          <li>PySpark</li>
          <li>Google ADK</li>
          <li>Apache Airflow</li>
        </ul>
      </div>
      <div class="category-card p-6" style="border: 3px solid #2a2a4a; background: rgba(18,18,31,0.5);">
        <h3 class="font-pixel text-lg mb-4" style="color: #4cc9f0;">CLOUD</h3>
        <ul class="space-y-2 text-sm" style="color: #a0a0b0;">
          <li>AWS (S3)</li>
          <li>Google Cloud Platform</li>
          <li>Vertex AI</li>
          <li>Docker / Kubernetes</li>
        </ul>
      </div>
      <div class="category-card p-6" style="border: 3px solid #2a2a4a; background: rgba(18,18,31,0.5);">
        <h3 class="font-pixel text-lg mb-4" style="color: #f4a261;">TOOLS</h3>
        <ul class="space-y-2 text-sm" style="color: #a0a0b0;">
          <li>Git / GitHub</li>
          <li>Scrum</li>
          <li>VS Code</li>
          <li>Figma</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .item-card { clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
  .item-card:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4); }
  .progress-fill { transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1); }
  .category-card { clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px); transition: all 0.3s ease; }
  .category-card:hover { border-color: #f4a261; transform: translateY(-2px); }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);
  gsap.from(".skill-item", { scrollTrigger: { trigger: "#skills", start: "top 60%" }, scale: 0.8, opacity: 0, duration: 0.6, stagger: 0.1, ease: "back.out(1.5)" });
  gsap.utils.toArray(".progress-fill").forEach((fill: any) => { gsap.to(fill, { width: fill.dataset.width + "%", duration: 1.5, ease: "power3.out", scrollTrigger: { trigger: "#skills", start: "top 60%" } }); });
</script>