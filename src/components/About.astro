---
---

<section id="about" class="min-h-screen py-20 px-4 relative overflow-hidden" style="width: 100%;">
  <!-- Fondo con gradiente -->
  <div class="absolute inset-0" style="background: linear-gradient(to bottom, #0a0a12, #12121f, #0a0a12);"></div>

  <div class="max-w-4xl mx-auto relative z-10" style="max-width: 56rem; margin: 0 auto; width: 100%;">
    <h2 class="font-pixel text-4xl md:text-5xl text-gold text-center mb-12 drop-shadow-[0_0_20px_rgba(244,162,97,0.3)]">
      ABOUT ME
    </h2>

    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div class="about-card p-6 border-3 border-[#2a2a4a] bg-[#12121f]/80 backdrop-blur-sm">
        <div class="flex items-center mb-4">
          <div class="w-12 h-12 bg-[#e63946] flex items-center justify-center mr-4" style="background: #e63946; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; margin-right: 16px;">
            <svg class="w-6 h-6 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 24px; height: 24px; color: white;">
              <path d="M14.5 17.5L3 6V3h3l11.5 11.5"/>
              <path d="M13 19l6-6"/>
              <path d="M16 16l4 4"/>
              <path d="M19 21l2-2"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-lg text-white">Ingeniero de Sistemas</h3>
            <p class="text-[#a0a0b0] text-sm">Formación profesional</p>
          </div>
        </div>
        <p class="text-[#a0a0b0] leading-relaxed">
          Profesional en Ingeniería de Sistemas con enfoque en desarrollo frontend y data engineering.
          Passion por crear experiencias web memorables y soluciones tecnológicas innovadoras.
        </p>
      </div>

      <div class="about-card p-6 border-3 border-[#2a2a4a] bg-[#12121f]/80 backdrop-blur-sm">
        <div class="flex items-center mb-4">
          <div class="w-12 h-12 bg-[#4cc9f0] flex items-center justify-center mr-4" style="background: #4cc9f0; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; margin-right: 16px;">
            <svg class="w-6 h-6 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 24px; height: 24px; color: white;">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-lg text-white">Enfoque</h3>
            <p class="text-[#a0a0b0] text-sm">Lo que me define</p>
          </div>
        </div>
        <p class="text-[#a0a0b0] leading-relaxed">
          Especializado en crear interfaces modernas, responsivas y accesibles.
          Siempre aprendiendo nuevas tecnologías y mejores prácticas de desarrollo.
        </p>
      </div>
    </div>

    <!-- Info adicional -->
    <div class="mt-12 text-center">
      <div class="inline-flex flex-wrap justify-center gap-6">
        <div class="stat-item">
          <svg class="w-8 h-8 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px; color: #f4a261;">
            <path d="M21 10c0 7-9 9-9 9s-9-2-9-9"/>
            <path d="M3.54 16.12a2.268 2.268 0 0 1-.24-2.52c.33-.97 1.1-1.6 2.03-1.6h10.46c.93 0 1.7.63 2.03 1.6.17.87.08 1.76-.24 2.52-.48 1.15-1.7 2.36-3.25 2.36s-2.77-1.21-3.25-2.36z"/>
          </svg>
          <p class="text-[#a0a0b0] mt-2">Medellín, Colombia</p>
        </div>
        <div class="stat-item">
          <svg class="w-8 h-8 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px; color: #f4a261;">
            <path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/>
            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
          <p class="text-[#a0a0b0] mt-2">Ing. Sistemas</p>
        </div>
        <div class="stat-item">
          <svg class="w-8 h-8 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px; color: #f4a261;">
            <rect x="2" y="7" width="20" height="14" rx="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
          <p class="text-[#a0a0b0] mt-2">Globant</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-card {
    clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
    transition: all 0.3s ease;
  }

  .about-card:hover {
    border-color: #f4a261;
    box-shadow: 0 0 30px rgba(244, 162, 97, 0.15);
    transform: translateY(-4px);
  }

  .stat-item {
    text-align: center;
    padding: 1rem;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".about-card", {
    scrollTrigger: {
      trigger: "#about",
      start: "top 70%",
    },
    opacity: 0,
    y: 50,
    duration: 0.8,
    stagger: 0.2,
    ease: "power3.out"
  });
</script>