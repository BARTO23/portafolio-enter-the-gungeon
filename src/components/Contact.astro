---
const email = "juanpablococtm@gmail.com";
const linkedin = "https://www.linkedin.com/in/juantobar/";
const github = "https://github.com/BARTO23";
---

<section id="contact" class="min-h-[60vh] py-20 px-4 relative" style="width: 100%;">
  <div class="absolute inset-0" style="background: linear-gradient(to bottom, #0a0a12, #12121f, #0a0a12);"></div>

  <div class="max-w-3xl mx-auto relative z-10 text-center" style="max-width: 48rem; margin: 0 auto; width: 100%;">
    <h2 class="font-pixel text-4xl md:text-5xl text-gold text-center mb-4 drop-shadow-[0_0_20px_rgba(244,162,97,0.3)]">
      CONTACT
    </h2>
    <p class="text-[#a0a0b0] text-center mb-12 font-heading">
      ¡Hablemos! Encuentrame en:
    </p>

    <div class="grid md:grid-cols-3 gap-4 mb-12">
      <!-- Email -->
      <a href={`mailto:${email}`} class="contact-card group">
        <div class="card-content p-6" style="border: 3px solid #2a2a4a; background: #12121f;">
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center rounded-full transition-colors" style="background: rgba(230,57,70,0.2);">
            <svg class="w-7 h-7" style="color: #e63946;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </div>
          <h3 class="font-pixel text-sm text-white mb-1">Email</h3>
          <p class="text-[#a0a0b0] text-xs truncate">{email}</p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a href={linkedin} target="_blank" rel="noopener noreferrer" class="contact-card group">
        <div class="card-content p-6" style="border: 3px solid #2a2a4a; background: #12121f;">
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center rounded-full transition-colors" style="background: rgba(76,201,240,0.2);">
            <svg class="w-7 h-7" style="color: #4cc9f0;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <h3 class="font-pixel text-sm text-white mb-1">LinkedIn</h3>
          <p class="text-[#a0a0b0] text-xs">juantobar</p>
        </div>
      </a>

      <!-- GitHub -->
      <a href={github} target="_blank" rel="noopener noreferrer" class="contact-card group">
        <div class="card-content p-6" style="border: 3px solid #2a2a4a; background: #12121f;">
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center rounded-full transition-colors" style="background: rgba(244,162,97,0.2);">
            <svg class="w-7 h-7" style="color: #f4a261;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <h3 class="font-pixel text-sm text-white mb-1">GitHub</h3>
          <p class="text-[#a0a0b0] text-xs">BARTO23</p>
        </div>
      </a>
    </div>

    <!-- Footer -->
    <div class="pt-8 border-t border-[#2a2a4a]">
      <p class="text-[#a0a0b0] text-sm">
        <svg class="w-5 h-5 inline mr-1" style="color: #f4a261;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m14.5 17.5L3 6V3h3l11.5 11.5"/><path d="M13 19l6-6"/><path d="M16 16l4 4"/><path d="M19 21l2-2"/></svg>
        Creado con estilo Enter the Gungeon
      </p>
      <p class="text-[#a0a0b0] text-xs mt-2">
        © 2026 Juan Tobar. All rights reserved.
      </p>
    </div>
  </div>
</section>

<style>
  .contact-card {
    display: block;
  }

  .card-content {
    clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-content:hover {
    border-color: #f4a261;
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.4), 0 0 30px rgba(244, 162, 97, 0.15);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".contact-card", {
    scrollTrigger: {
      trigger: "#contact",
      start: "top 70%",
    },
    opacity: 0,
    y: 40,
    duration: 0.8,
    stagger: 0.15,
    ease: "back.out(1.5)"
  });
</script>